# Coding Cold Cases Cracker
#
# Normal usage:
#   cp .env.example .env
#   docker compose up --build

# Optional host port overrides if 3000 or 7681 is already in use.
HOST_APP_PORT=3000
HOST_TERMINAL_PORT=7681

# Optional but recommended. Enables fully unattended Kiro autopilot mode.
# Leave blank to use interactive Kiro device/browser login in the Dockerized terminal.
KIRO_API_KEY=

# Required for Lark workflow validation, provisioning, and execution.
GETLARK_API_KEY=

# Permanent repository where generated case workspaces can be published for Lark/user review.
GITHUB_REPO_URL=https://github.com/egocks/coding-cold-cases-cracker.git

# Optional for publishing generated case workspaces.
GITHUB_TOKEN=
